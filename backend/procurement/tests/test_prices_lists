class Block2IntegrationTest(APITestCase):
    \"\"\"Интеграционные тесты\"\"\"

    def setUp(self):
        self.client = APIClient()
        self.user = User.objects.create_superuser('test', 'test@example.com', 'test123')
        self.client.force_authenticate(user=self.user)
        
        self.supplier = supplier_factory()
        self.unit = unit_factory()
        self.item = item_factory()

    def test_full_workflow(self):
        \"\"\"Полный workflow: прайс-лист → позиция → сопоставление\"\"\"

        # 1. Создать прайс-лист
        pl_data = {
            'supplier': self.supplier.id,
            'name': 'Full Test',
            'version': '1.0',
            'effective_date': '2026-01-18'
        }
        pl_response = self.client.post('/api/procurement/supplier-price-lists/', pl_data)
        price_list_id = pl_response.data['id']

        # 2. Создать позицию
        line_data = {
            'price_list': price_list_id,
            'supplier_sku': 'TEST-001',
            'description': 'Test Item',
            'unit': self.unit.id,
            'price': '10.00'
        }
        line_response = self.client.post('/api/procurement/price-list-lines/', line_data)
        line_id = line_response.data['id']

        # 3. Создать сопоставление
        mapping_data = {
            'item': self.item.id,
            'price_list_line': line_id,
            'conversion_factor': '1.0'
        }
        mapping_response = self.client.post('/api/procurement/item-supplier-mappings/', mapping_data)
        self.assertEqual(mapping_response.status_code, status.HTTP_201_CREATED)

        # 4. Проверить всё создано
        self.assertEqual(SupplierPriceList.objects.count(), 2)
        self.assertEqual(SupplierPriceListLine.objects.count(), 2)
        self.assertEqual(ItemSupplierMapping.objects.count(), 1)


if __name__ == '__main__':
    pytest.main(['-v', __file__])
