    ItemSupplierMapping
)
from procurement.tests.factories import (
    supplier_factory, item_factory, unit_factory,
    price_list_factory, price_line_factory, mapping_factory
)

User = get_user_model()

class Block2ModelsTest(TestCase):
    \"\"\"Тесты моделей Прайс-листов\"\"\"

    def setUp(self):
        self.supplier = supplier_factory()
        self.unit = unit_factory()
        self.item = item_factory()
        self.price_list = price_list_factory(supplier=self.supplier)

    def test_supplier_price_list_methods(self):
        \"\"\"Тест методов SupplierPriceList\"\"\"

        # Активный прайс-лист
        pl = SupplierPriceList.objects.create(
            supplier=self.supplier,
            name='Test Active',
            version='1.0',
            effective_date=date.today(),
            is_active=True
        )
        self.assertTrue(pl.is_valid_today())
        self.assertIsNone(pl.days_until_expiry())

        # Истёкший
        pl.effective_date = date.today() - timedelta(days=1)
        pl.save()
        self.assertFalse(pl.is_valid_today())

    def test_price_list_line_calculations(self):
        \"\"\"Тест расчётов цен\"\"\"

        line = SupplierPriceListLine.objects.create(
            price_list=self.price_list,
            supplier_sku='TEST-001',
            description='Тест товар',
            unit=self.unit,
            price=Decimal('10.00'),
            min_quantity=100,
            vat_included=False,
            vat_rate=20
        )

        # Базовая цена
        self.assertEqual(line.price, Decimal('10.00'))

        # Эффективная цена (с НДС)
        self.assertEqual(line.effective_price, Decimal('12.00'))

        # Расчёт количества
        result = line.calculate_total_for_quantity(150)
        self.assertTrue(result['valid'])
        self.assertEqual(result['total'], Decimal('1800.00'))

        # Недостаточное количество
        result = line.calculate_total_for_quantity(50)
        self.assertFalse(result['valid'])
        self.assertIn('100', result['error'])

    def test_item_supplier_mapping_conversions(self):
        \"\"\"Тест конвертации единиц\"\"\"

        line = price_line_factory(price_list=self.price_list)
        mapping = ItemSupplierMapping.objects.create(
            item=self.item,
            price_list_line=line,
            conversion_factor=Decimal('2.5'),  # 1 Item = 2.5 ед. поставщика
            is_preferred=True
        )

        # Конвертация Item → Supplier
        self.assertEqual(mapping.convert_item_qty_to_supplier_qty(4), Decimal('10.0'))

        # Конвертация Supplier → Item
        self.assertEqual(mapping.convert_supplier_qty_to_item_qty(10), Decimal('4.0'))

        # Эффективный МОК
        self.assertEqual(mapping.get_effective_min_quantity(), Decimal('250.0'))


class Block2APITest(APITestCase):
    \"\"\"Тесты API Блока 2\"\"\"

