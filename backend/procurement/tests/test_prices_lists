        self.item = item_factory()
        self.price_list = price_list_factory(supplier=self.supplier)

    def test_price_list_list_empty(self):
        \"\"\"GET /supplier-price-lists/ — пустой список\"\"\"

        response = self.client.get('/api/procurement/supplier-price-lists/')
        self.assertEqual(response.status_code, status.HTTP_200_OK)
        self.assertEqual(response.data['count'], 0)

    def test_create_price_list(self):
        \"\"\"POST /supplier-price-lists/ — создание\"\"\"

        data = {
            'supplier': self.supplier.id,
            'name': 'Тестовый прайс-лист',
            'version': '1.0',
            'effective_date': '2026-01-18'
        }
        response = self.client.post('/api/procurement/supplier-price-lists/', data)
        self.assertEqual(response.status_code, status.HTTP_201_CREATED)
        self.assertEqual(response.data['name'], 'Тестовый прайс-лист')

        # Проверить создание
        self.assertEqual(SupplierPriceList.objects.count(), 2)

    def test_price_list_detail(self):
        \"\"\"GET /supplier-price-lists/1/ — детали\"\"\"

        response = self.client.get(f'/api/procurement/supplier-price-lists/{self.price_list.id}/')
        self.assertEqual(response.status_code, status.HTTP_200_OK)
        self.assertEqual(response.data['id'], self.price_list.id)

    def test_price_list_active_filter(self):
        \"\"\"GET /supplier-price-lists/active/ — только активные\"\"\"

        # Создать неактивный
        inactive = price_list_factory(is_active=False)
        
        response = self.client.get('/api/procurement/supplier-price-lists/active/')
        self.assertEqual(response.status_code, status.HTTP_200_OK)
        self.assertEqual(response.data['count'], 1)  # Только self.price_list активный

    def test_price_line_create(self):
        \"\"\"POST /price-list-lines/ — позиция\"\"\"

        data = {
            'price_list': self.price_list.id,
            'supplier_sku': 'KR-001',
            'description': 'Кирпич красный',
            'unit': self.unit.id,
            'price': '15.00'
        }
        response = self.client.post('/api/procurement/price-list-lines/', data)
        self.assertEqual(response.status_code, status.HTTP_201_CREATED)
        self.assertEqual(response.data['supplier_sku'], 'KR-001')

    def test_item_mapping_create(self):
        \"\"\"POST /item-supplier-mappings/ — сопоставление\"\"\"

        line = price_line_factory(price_list=self.price_list)
        
        data = {
            'item': self.item.id,
            'price_list_line': line.id,
            'conversion_factor': '1.0',
            'is_preferred': True
        }
        response = self.client.post('/api/procurement/item-supplier-mappings/', data)
        self.assertEqual(response.status_code, status.HTTP_201_CREATED)

    def test_find_alternative_suppliers(self):
        \"\"\"GET /item-supplier-mappings/find-alternative/\"\"\"

        # Создать сопоставления
        line1 = price_line_factory(price_list=self.price_list)
        line2 = price_line_factory()
